# Coordinator LLM used by AIGateway("anthropic/claude-sonnet-4")
AI_GATEWAY_API_KEY=your-ai-gateway-api-key-here

# Codex / OpenAI-compatible runtime credentials (optional; native CLI auth may also be used)
# OPENAI_API_KEY=your-openai-api-key-here
# CODEX_API_KEY=your-codex-api-key-here
# CODEX_HOME=/path/to/codex/home

# Claude Code / Claude Agent SDK credentials (optional; native Claude login may also be used locally)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_AUTH_TOKEN=your-anthropic-auth-token-here
# CLAUDE_CODE_OAUTH_TOKEN=your-claude-code-oauth-token-here
# CLAUDE_CONFIG_DIR=/path/to/claude/config

# Gemini CLI credentials (optional; native Gemini/Google auth may also be used)
# GEMINI_API_KEY=your-gemini-api-key-here
# GOOGLE_API_KEY=your-google-api-key-here
# GOOGLE_GENAI_USE_VERTEXAI=false
# GOOGLE_CLOUD_PROJECT=your-google-cloud-project
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
